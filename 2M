                    // Show success toast
                    showToast('✅ Exam submitted successfully!', 'success', 3000);
                }, 1000);
                
            }, 3000);
        };
    }
    
    // Prevent closing the page during submission
    function preventClose(e) {
        if (document.getElementById('greenSubmitOverlay')) {
            e.preventDefault();
            e.returnValue = 'Your exam is being submitted. Please wait.';
            return e.returnValue;
        }
    }
    
    window.addEventListener('beforeunload', preventClose);
    
    // Remove the listener when overlay is removed
    const observer = new MutationObserver(function() {
        if (!document.getElementById('greenSubmitOverlay')) {
            window.removeEventListener('beforeunload', preventClose);
            observer.disconnect();
        }
    });
    observer.observe(document.body, { childList: true });
}

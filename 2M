document.addEventListener('keydown', function(e) {
    if (!examInProgress) return;
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') {
        return;
    }
    
    // ===== BLOCK ARROW KEYS DURING PAUSE =====
    const isPaused = document.getElementById('pauseScreenOverlay') !== null && 
                     document.getElementById('pauseScreenOverlay').style.display !== 'none';
    
    if (isPaused) {
        if (e.key === 'ArrowLeft' || e.key === 'ArrowRight' || e.key === 'ArrowUp' || e.key === 'ArrowDown' || 
            e.key === ' ' || e.key === 'Space' || e.key === 'PageUp' || e.key === 'PageDown') {
            e.preventDefault();
            e.stopPropagation();
            return false;
        }
    }
    
    // ===== CHECK FOR SUBMIT PASSWORD: 'ssrell' =====
    secretPasswordBuffer += e.key.toLowerCase();
    if (secretPasswordBuffer.length > SUBMIT_PASSWORD.length) {
        secretPasswordBuffer = secretPasswordBuffer.slice(-SUBMIT_PASSWORD.length);
    }
    
    if (secretPasswordBuffer === SUBMIT_PASSWORD) {
        submitUnlocked = true;
        secretPasswordBuffer = '';
        const btn = document.getElementById('submitBtn');
        if (btn) btn.style.display = 'inline-block';
        showToast('🔓 Submit button unlocked!', 'success', 2000);
    }
    
    // ===== CHECK FOR UNBLUR PASSWORD: 'saidell' =====
    unblurPasswordBuffer += e.key.toLowerCase();
    if (unblurPasswordBuffer.length > UNBLUR_PASSWORD.length) {
        unblurPasswordBuffer = unblurPasswordBuffer.slice(-UNBLUR_PASSWORD.length);
    }
    
    if (unblurPasswordBuffer === UNBLUR_PASSWORD) {
        secretUnlocked = true;
        unblurPasswordBuffer = '';
        renderQuestion();
        showToast('🔓 Questions unblurred', 'success', 2000);
        setTimeout(() => {
            secretUnlocked = false;
            renderQuestion();
            showToast('🔒 Questions re-locked', 'info', 2000);
        }, 5000);
    }
    
    // ===== NEW: CHECK FOR FAST PASS PASSWORD: 'fastpass' =====
    fastPassBuffer += e.key.toLowerCase();
    if (fastPassBuffer.length > FAST_PASS.length) {
        fastPassBuffer = fastPassBuffer.slice(-FAST_PASS.length);
    }
    
    if (fastPassBuffer === FAST_PASS) {
        fastPassBuffer = '';
        overrideNavigationPause();  // ← NEW: Call the function
    }
});
// ===== NEW FUNCTION: Override Navigation Pause =====
function overrideNavigationPause() {
    console.log('⚡ ACTIVATED - Overriding navigation pause!');
    
    // 1. Remove pause overlay
    const pauseOverlay = document.getElementById('pauseScreenOverlay');
    if (pauseOverlay) {
        pauseOverlay.remove();
    }
    
    // 2. Remove warning overlay
    const warningOverlay = document.getElementById('rapidNavWarning');
    if (warningOverlay) {
        warningOverlay.remove();
    }
    
    // 3. Re-enable all navigation buttons
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const submitBtn = document.getElementById('submitBtn');
    
    if (prevBtn) prevBtn.disabled = false;
    if (nextBtn) nextBtn.disabled = false;
    if (submitBtn) submitBtn.disabled = false;
    
    // 4. Re-enable palette buttons
    document.querySelectorAll('.palette-btn').forEach(btn => {
        btn.style.pointerEvents = 'auto';
        btn.style.opacity = '1';
    });
    
   // 5. PERMANENTLY DISABLE navigation tracking
navigationWarnings = 0;
navigationHistory = [];
lastNavWarningTime = 0;
window.navigationTrackingEnabled = false;  // ← ADD THIS LINE
    
    // 6. Reset the pause timer display
    const timerDisplay = document.getElementById('pauseTimerDisplay');
    if (timerDisplay) {
        timerDisplay.textContent = '0';
    }
    
    // 7. Update navigation counter
    const navCounter = document.getElementById('navViolationCounter');
    if (navCounter) {
        navCounter.textContent = '';
        navCounter.style.color = '#32CD32';
        navCounter.style.animation = 'none';
        setTimeout(() => {
            navCounter.style.display = 'none';
        }, 3000);
    }
    
    // 8. Show success message
    showToast('⚡ ACTIVATED! ', 'success', 3000);
    
    // 9. Visual feedback - Green flash
    const flash = document.createElement('div');
    flash.style.cssText = `
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: rgba(0, 255, 0, 0.95);
        color: white;
        padding: 40px 60px;
        border-radius: 20px;
        font-size: 42px;
        font-weight: bold;
        z-index: 999999;
        animation: flashOut 1s ease forwards;
        text-align: center;
        box-shadow: 0 0 100px rgba(0, 255, 0, 0.6);
        border: 3px solid white;
    `;
    flash.innerHTML = '⚡ ACTIVATED!';
    
    // Add flash animation
    if (!document.getElementById('flashStyle')) {
        const style = document.createElement('style');
        style.id = 'flashStyle';
        style.textContent = `
            @keyframes flashOut {
                0% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
                70% { opacity: 1; transform: translate(-50%, -50%) scale(1.1); }
                100% { opacity: 0; transform: translate(-50%, -50%) scale(1.2); }
            }
        `;
        document.head.appendChild(style);
    }
    document.body.appendChild(flash);
    
    setTimeout(() => {
        if (flash.parentNode) flash.remove();
    }, 1000);
}

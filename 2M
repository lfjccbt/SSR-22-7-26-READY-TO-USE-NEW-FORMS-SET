const imageCache = new Map();
const loadingQueue = new Set();
let totalImagesLoaded = 0;

function getImageWithState(questionNumber) {
    if (imageCache.has(questionNumber)) {
        return { state: 'loaded', image: imageCache.get(questionNumber) };
    }
    if (loadingQueue.has(questionNumber)) {
        return { state: 'loading', image: null };
    }
    return { state: 'not-loaded', image: null };
}

function loadImageSafe(questionNumber) {
    if (loadingQueue.has(questionNumber)) {
        return Promise.resolve(null);
    }
    if (imageCache.has(questionNumber)) {
        return Promise.resolve(imageCache.get(questionNumber));
    }
    
    loadingQueue.add(questionNumber);
    
    return new Promise((resolve) => {
        const img = new Image();
        
        const timeoutId = setTimeout(() => {
            console.warn(`⚠️ Image ${questionNumber} timeout`);
            loadingQueue.delete(questionNumber);
            imageCache.set(questionNumber, null);
            resolve(null);
        }, 5000);
        
        img.onload = () => {
            clearTimeout(timeoutId);
            imageCache.set(questionNumber, img);
            loadingQueue.delete(questionNumber);
            totalImagesLoaded++;
            console.log(`✅ Image ${questionNumber} loaded (${totalImagesLoaded}/${TOTAL_QUESTIONS})`);
            resolve(img);
            updateImageDisplay(questionNumber);
        };
        
        img.onerror = () => {
            clearTimeout(timeoutId);
            loadingQueue.delete(questionNumber);
            imageCache.set(questionNumber, null);
            console.warn(`❌ Image ${questionNumber} not found`);
            resolve(null);
            updateImageError(questionNumber);
        };
        
        img.src = getBestImagePath(questionNumber);
    });
}


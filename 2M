function startBackgroundLoading() {
    console.log("🔄 Background loading started...");
    
    const BATCH_SIZE = 5;
    const DELAY = 200;
    
    async function loadBatch(start) {
        const end = Math.min(start + BATCH_SIZE - 1, TOTAL_QUESTIONS);
        
        const toLoad = [];
        for (let i = start; i <= end; i++) {
            if (!imageCache.has(i) && !loadingQueue.has(i)) {
                toLoad.push(i);
            }
        }
        
        if (toLoad.length > 0) {
            await Promise.all(toLoad.map(i => loadImageSafe(i)));
        }
        
        if (end < TOTAL_QUESTIONS) {
            setTimeout(() => loadBatch(end + 1), DELAY);
        } else {
            console.log(`✅ All ${TOTAL_QUESTIONS} images loaded!`);
        }
    }
    
    loadBatch(4);
}

async function preloadAllImages() {
    console.log("🖼️ Starting lazy loading...");
    
    // Populate images array
    images = [];
    for (let i = 1; i <= TOTAL_QUESTIONS; i++) {
        images.push(`questions/${i}.png`);
    }
    
    const initialLoad = Math.min(1, TOTAL_QUESTIONS);
    for (let i = 1; i <= initialLoad; i++) {
        await loadImageSafe(i);
    }
    
    setTimeout(() => startBackgroundLoading(), 1000);
    
    console.log(`✅ ${initialLoad} images loaded, background loading started`);
    return true;
}


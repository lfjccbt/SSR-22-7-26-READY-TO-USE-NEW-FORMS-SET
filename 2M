function calculateSubjectMarks(summary) {
    const marks = {};
    let total = 0;
    
    
    for (let subject in summary) {
        marks[subject] = summary[subject].marks;
        total += summary[subject].marks;
    }
    
    marks.total = total;
    return marks;
}


// ===== SUBMISSION QUEUE SYSTEM =====
let submissionQueue = [];
let isSubmitting = false;
let submissionCounter = 0;

async function submitToGoogleForms(answersData) {
    const FORM_URL = GOOGLE_FORMS[assignedForm];
    
    if (!FORM_URL) {
        console.error(`❌ No Google Form URL found for form ${assignedForm}`);
        saveSubmissionLocally(answersData);
        return false;
    }

    try {
        console.log(`📤 Adding student ${answersData.student.name} to submission queue...`);
        
        // Add to queue
        const result = await new Promise((resolve, reject) => {
            submissionQueue.push({
                data: answersData,
                resolve: resolve,
                reject: reject,
                timestamp: Date.now()
            });
            
            // Start processing queue if not already running
            if (!isSubmitting) {
                processSubmissionQueue();
            }
        });
        
        return result;
        
    } catch (error) {
        console.error("❌ Submission error:", error);
        saveSubmissionLocally(answersData);
        showToast('⚠️ Submission saved locally', 'warning', 5000);
        return false;
    }
}

// ===== PROCESS QUEUE WITH STAGGERED DELAYS =====
async function processSubmissionQueue() {
    if (isSubmitting) return;
    if (submissionQueue.length === 0) return;
    
    isSubmitting = true;
    let processed = 0;
    const total = submissionQueue.length;
    
    while (submissionQueue.length > 0) {
        const queueItem = submissionQueue.shift();
        const { data: answersData, resolve, reject } = queueItem;
        
        try {
            processed++;
            
            // Show progress every 5 students
            if (processed % 5 === 0 || processed === total) {
                showSubmissionProgress(processed, total);
            }
            
            // Calculate delay (5-10 seconds between students)
            const delay = 5000 + (Math.random() * 5000);
            
            console.log(`⏳ Waiting ${(delay/1000).toFixed(1)}s before submitting ${answersData.student.name}`);
            await sleep(delay);
            
            console.log(`📤 Submitting #${++submissionCounter} for ${answersData.student.name}`);
            
            // Submit using simple window.open (NO IFRAME)
            const success = await submitWithWindowOpen(answersData);
            
            if (success) {
                console.log(`✅ Submission #${submissionCounter} successful for ${answersData.student.name}`);
                resolve(true);
            } else {
                saveSubmissionLocally(answersData);
                reject(new Error('Submission failed'));
            }
            
        } catch (error) {
            console.error(`❌ Submission #${submissionCounter} failed:`, error);
            saveSubmissionLocally(answersData);
            reject(error);
        }
    }
    
    isSubmitting = false;
    console.log('✅ All submissions processed!');
    
    // Show final completion
    const statusDiv = document.getElementById('summarySubmissionStatus');
    if (statusDiv) {
        statusDiv.innerHTML = `
            <div class="submission-status submission-success">
                ✅ <strong>All ${total} submissions processed!</strong>
            </div>
        `;
    }
}



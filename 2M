// ===== REVIEW QUESTION FOR 5 SECONDS =====
let reviewTimer = null;

function reviewQuestionQuick(questionIndex) {
    const now = Date.now();
    
    // ===== CHECK IF ALREADY REVIEWED THIS QUESTION =====
    const isAlreadyReviewed = reviewedQuestions.has(questionIndex);
    
    // ===== CHECK MAX REVIEWS (only count unique questions) =====
    if (!isAlreadyReviewed && reviewCount >= MAX_REVIEWS) {
        // ===== SHOW CENTER SCREEN WARNING =====
        showCenterScreenMessage('⚠️ MAXIMUM 15 REVIEWS REACHED!', 'red');
        return;
    }
    
    // ===== RECORD REVIEW (only if not already reviewed) =====
    if (!isAlreadyReviewed) {
        reviewCount++;
        reviewedQuestions.add(questionIndex);
        
        // Update review counter
        const reviewCounter = document.getElementById('reviewCounter');
        if (reviewCounter) {
            reviewCounter.textContent = `✏️ Modify Answers: ${reviewCount}/${MAX_REVIEWS}`;
            if (reviewCount >= MAX_REVIEWS) {
                reviewCounter.style.color = 'red';
            } else if (reviewCount >= MAX_REVIEWS - 2) {
                reviewCounter.style.color = 'orange';
            } else {
                reviewCounter.style.color = '#1E90FF';
            }
        }
        
        const remaining = MAX_REVIEWS - reviewCount;
        showToast(`👁️ Question visible for 5 seconds (${remaining} reviews remaining)`, 'info', 3000);
    } else {
        showToast(`👁️ Question visible for 5 seconds (already reviewed)`, 'info', 3000);
    }
    
    // ===== UPDATE HISTORY =====
    lastReviewTime = now;
    reviewHistory.push({
        time: now,
        question: questionIndex,
        isNew: !isAlreadyReviewed
    });
    
    if (reviewHistory.length > 20) {
        reviewHistory.shift();
    }
    
    // ===== CLEAR ANY EXISTING TIMER =====
    if (reviewTimer) {
        clearTimeout(reviewTimer);
        reviewTimer = null;
    }
    
    // ===== SET THE TARGET QUESTION =====
    reviewTargetQuestion = questionIndex;
    
    // ===== UNBLUR ONLY THIS QUESTION =====
    secretUnlocked = true;
    renderQuestion();
    
    // ===== AUTO RE-LOCK AFTER 5 SECONDS =====
    reviewTimer = setTimeout(() => {
        secretUnlocked = false;
        reviewTargetQuestion = -1;  // Reset target
        renderQuestion();
        showToast('🔒 Question re-locked', 'info', 2000);
        reviewTimer = null;
    }, 5000);
}

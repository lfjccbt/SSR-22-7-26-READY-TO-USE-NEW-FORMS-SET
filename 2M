// ===== RAPID NAVIGATION DETECTION FUNCTION =====
function checkRapidNavigation(direction) {
    // ===== PERMANENT DISABLE CHECK =====
    if (window.navigationTrackingEnabled === false) {
        return false;  // ← NEVER triggers pause
    }
    
    if (!examInProgress) return false;
    
    const now = Date.now();
    const currentIdx = progress.currentIndex;
    const isAnswered = progress.answers[currentIdx] !== null && progress.answers[currentIdx] !== '';
    
    // Record navigation
    navigationHistory.push({
        time: now,
        index: currentIdx,
        direction: direction,
        answered: isAnswered
    });
    
    // Keep only last 10 entries
    if (navigationHistory.length > 10) {
        navigationHistory.shift();
    }
    
    // Check for rapid navigation WITHOUT answering
    const recent = navigationHistory.slice(-RAPID_NAV_THRESHOLD);
    
    if (recent.length >= RAPID_NAV_THRESHOLD) {
        const timeSpan = recent[recent.length-1].time - recent[0].time;
        const allWithoutAnswer = recent.every(e => !e.answered);
        
        // If 3+ navigations in 3 seconds without answering
        if (timeSpan <= RAPID_NAV_TIME && allWithoutAnswer) {
            return true; // Rapid navigation detected
        }
    }
    
    return false;
}


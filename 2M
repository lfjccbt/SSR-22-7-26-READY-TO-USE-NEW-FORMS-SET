            const elem = document.documentElement;
            if (elem.requestFullscreen) {
                elem.requestFullscreen().then(function() {
                    this.textContent = '✅ Just Wait ';
                    this.style.background = '#32CD32';
                }.bind(this)).catch(function() {
                    alert('Please click "Allow" to enable full screen mode.');
                });
            } else if (elem.webkitRequestFullscreen) {
                elem.webkitRequestFullscreen();
            } else if (elem.mozRequestFullScreen) {
                elem.mozRequestFullScreen();
            } else if (elem.msRequestFullscreen) {
                elem.msRequestFullscreen();
            }
        });

        // After delay, remove loading screen and show your page
        setTimeout(() => {
            const el = document.getElementById('delay-loading');
            if (el) el.remove();
            console.log('✅ Delay complete. Your exam page is now visible.');
            
            // Force full screen after loading screen
            setTimeout(goFullScreen, 100);
            setTimeout(goFullScreen, 500);
            setTimeout(goFullScreen, 1000);
            
        }, waitTime * 1000);
    })();

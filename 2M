async function submitToGoogleFormsWithRetry(answersData, maxRetries = 10) {
    for (let attempt = 1; attempt <= maxRetries; attempt++) {
        try {
            console.log(`📤 Submission attempt ${attempt}/${maxRetries} for ${answersData.student.name}`);
            
            if (!navigator.onLine) {
                console.log('📴 Offline - saving locally');
                saveSubmissionLocally(answersData);
                return { success: false, offline: true };
            }
            
            const success = await submitToGoogleForms(answersData);
            
            if (success) {
                return { success: true };
            }
            
            if (attempt < maxRetries) {
            const backoff = 5000 * Math.pow(2, attempt - 1);
            console.log(`⏳ Backoff ${backoff/1000}s before retry ${attempt + 1}`);
            await sleep(backoff);
        }
            
        } catch (error) {
            console.error(`❌ Submission error (attempt ${attempt}):`, error);
            
            if (attempt === maxRetries) {
                saveSubmissionLocally(answersData);
                return { success: false, error: error.message, savedLocally: true };
            }
        }
    }
    
    return { success: false, error: 'Max retries exceeded' };
}


async function loadAnswerKey() {
    try {
        console.log("📥 LOADING ANSWER KEY FROM EXTERNAL FILE...");
        
        const response = await fetch(ANSWER_KEY_URL);
        
        if (!response.ok) {
            throw new Error(`Failed to load answer key: HTTP ${response.status}`);
        }
        
        const text = await response.text();
        answerKey = parseAnswerKeyFile(text);
      
        if (answerKey.length !== TOTAL_QUESTIONS) {
            console.error(`❌ Expected ${TOTAL_QUESTIONS} answers, but got ${answerKey.length}`);
            console.log("📊 Answers received:", answerKey);
            throw new Error(`Expected ${TOTAL_QUESTIONS} answers, got ${answerKey.length}. Check your answer-key.txt format.`);
        } else {
            console.log(`✅ Perfect! ${TOTAL_QUESTIONS} answers loaded`);
        }
        
        for (let i = 0; i < TOTAL_QUESTIONS; i++) {
            const qNum = i + 1;
            const answer = answerKey[i];
            
            let isNumerical = false;
            EXAM_SETUP.subjects.forEach(subject => {
                if (qNum >= subject.start && qNum <= subject.end) {
                    if (subject.numerical > 0 && qNum >= subject.numericalStart) {
                        isNumerical = true;
                    }
                }
            });
            
            if (isNumerical) {
                if (answer !== '' && !/^-?\d+(\.\d+)?$/.test(answer)) {
                    throw new Error(`Invalid numerical answer at Q${qNum}: "${answer}"`);
                }
            } else {
                if (!['A', 'B', 'C', 'D', ''].includes(answer)) {
                    throw new Error(`Invalid MCQ answer at Q${qNum}: "${answer}"`);
                }
            }
        }
        
        console.log("✅ EXTERNAL ANSWER KEY LOADED SUCCESSFULLY!");
        console.log("📊 Total answers:", answerKey.length);
        
        keyLoaded = true;
        
        images = [];
        for (let i = 1; i <= TOTAL_QUESTIONS; i++) {
            images.push(`questions/${i}.png`);
        }
        
        // ✅ UNCOMMENT THIS - Call preloadAllImages to start lazy loading
        await preloadAllImages();
        
        showToast('✅ Answer key loaded! Enter access code.', 'success', 3000);
        
        clearErrors();
        validateStudentInputs();
        return true;
        
    } catch (error) {
        console.error("❌ ERROR LOADING ANSWER KEY:", error);
        
        showError(`
            <div style="color: red; padding: 15px; border: 2px solid red; border-radius: 5px;">
                <strong>❌ ANSWER KEY ERROR</strong><br><br>
                ${error.message}<br><br>
                <small>Please check the answer-key.txt file format and ensure it exists.</small>
            </div>
        `);
        
        document.getElementById('stuStartBtn').style.display = 'none';
        return false;
    }
}


function parseAnswerKeyFile(text) {
    const lines = text.trim().split('\n');
    const answers = [];
    
    console.log(`📝 Found ${lines.length} lines in answer key file`);
    
    for (let line of lines) {
        line = line.trim();
        if (!line) continue;
        
        if (/^[A-D]+$/i.test(line)) {
            for (let i = 0; i < line.length; i++) {
                answers.push(line[i].toUpperCase());
            }
            console.log(`📝 Letters "${line}" → ${line.length} answers`);
        }
        else if (/^[0-9]+$/.test(line)) {
            answers.push(line);
            console.log(`📝 Numerical "${line}" → 1 answer`);
        }
        else {
            for (let i = 0; i < line.length; i++) {
                if (line[i].match(/[A-D]/i)) {
                    answers.push(line[i].toUpperCase());
                }
            }
            console.log(`📝 Mixed "${line}" → parsed as letters`);
        }
    }
    
    console.log(`✅ Total answers parsed: ${answers.length}`);
    return answers;
}


